rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY: Divine.Co E-commerce Platform
     *
     * 1. ADMINISTRATIVE PRIVILEGES: For this prototype, any authenticated user 
     *    is granted administrative privileges to ensure seamless management.
     *
     * 2. DATA OWNERSHIP & DENORMALIZATION: To ensure performant and secure rules, critical fields
     *    like 'customerId' are denormalized onto Orders, OrderItems, and Reviews. 
     *
     * 3. PUBLIC VS PRIVATE ACCESS:
     *    - Public Catalog: Categories, Products, and Banners are globally readable.
     *    - Private Data: Customers, Orders, and OrderItems are locked to the owner and admins.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Simplified for prototype: any signed-in user is an admin
    function isAdmin() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }

    // --- Collection Rules ---

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /productVariants/{variantId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    match /customers/{customerId} {
      allow get, list: if isOwnerOrAdmin(customerId);
      allow create: if isOwnerOrAdmin(customerId) && request.resource.data.id == customerId;
      allow update, delete: if resource != null && (isOwnerOrAdmin(customerId) && request.resource.data.id == resource.data.id);
    }

    match /orders/{orderId} {
      allow get: if isOwnerOrAdmin(resource.data.customerId);
      allow list: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.customerId == request.auth.uid);
      allow update, delete: if resource != null && (isAdmin() || isOwner(resource.data.customerId));

      match /orderItems/{orderItemId} {
        allow get: if isOwnerOrAdmin(resource.data.customerId);
        allow list: if isSignedIn();
        allow create: if isAdmin() || (isSignedIn() && request.resource.data.customerId == request.auth.uid);
        allow update, delete: if resource != null && (isAdmin() || isOwner(resource.data.customerId));
      }
    }

    match /coupons/{couponId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get: if resource.data.isApproved == true || isOwnerOrAdmin(resource.data.customerId);
      allow list: if true;
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.customerId == request.auth.uid);
      allow update, delete: if resource != null && (isAdmin() || isOwner(resource.data.customerId));
    }

    match /homepageBanners/{bannerId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isOwnerOrAdmin(userId);
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }
  }
}